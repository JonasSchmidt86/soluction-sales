<div class="modal fade" id="launchsModal<%= bill.cod_contaspagrec %>" tabindex="-1">
  <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
    <div class="modal-content shadow">
      <!-- HEADER -->
      <div class="modal-header bg-primary text-white">
        <h5 class="modal-title mb-0">
          <i class="fa fa-list me-2"></i> Lançamentos
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <!-- BODY -->
      <div class="modal-body p-2">
        <div class="table-responsive">
          <table class="table table-sm table-hover align-middle mb-0">
            <thead class="table-light text-center">
              <tr>
                <th>Colaborador</th>
                <th>Descrição</th>
                <th>Parcela</th>
                <th>Data</th>
                <th class="text-end">Valor</th>
              </tr>
            </thead>
            <tbody>
              <% sorted_lancamentos = bill.lancamentos.sort_by(&:datapagto) %>
              <% sorted_lancamentos.each do |launch| %>
                <% if launch.tipo == 'S' %>
                  <tr class="table-danger">
                  <% else %>
                    <tr class="table-success">
                    <% end %>
                    <td><%= launch.funcionario.usuario %></td>
                    <td>
                      <span class="text-muted small">
                        <%= launch.historico_descricao %>
                      </span>
                    </td>
                    <td class="text-center">
                      <span class="badge bg-secondary">
                        <%= bill.nmParcela %>
                      </span>
                    </td>
                    <td class="text-center">
                      <%= post_datetime launch.datapagto %>
                    </td>
                    <td class="text-end fw-semibold">
                      <%= number_to_currency(launch.valor, separator: ",", delimiter: ".", unit: "R$ ") %>
                    </td>
                  </tr>
                <% end %>
                <% if sorted_lancamentos.empty? %>
                  <tr>
                    <td colspan="5" class="text-center text-muted py-3">
                      Nenhum lançamento encontrado
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
        <!-- FOOTER -->
        <div class="modal-footer justify-content-between">
          <small class="text-muted">
            Total de lançamentos: <%= sorted_lancamentos.size %>
          </small>
          <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">
            Fechar
          </button>
        </div>
      </div>
    </div>
  </div>